{
  "name": "hex-theme-validator",
  "displayName": "Hex - VS Code Theme Validator",
  "description": "Because while you may be valid, your theme is questionable.",
  "version": "0.2.1",
  "publisher": "gesslar",
  "license": "0BSD",
  "engines": {
    "vscode": ">=1.104.0",
    "node": ">=24.11.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gesslar/Hex"
  },
  "categories": [
    "Other",
    "Themes"
  ],
  "keywords": [
    "vscode",
    "theme",
    "themes",
    "validation",
    "validator",
    "fenny",
    "snake",
    "syntax",
    "highlight",
    "json"
  ],
  "main": "./src/silly-required-cjs-entrypoint.cjs",
  "contributes": {
    "commands": [
      {
        "command": "hex.show",
        "title": "Hex: Show Hex"
      },
      {
        "command": "hex.validate",
        "title": "Validate selected theme file in Hex",
        "icon": "$(symbol-color)"
      },
      {
        "command": "hex.select",
        "title": "Open and validate theme file in Hex",
        "icon": "$(symbol-color)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "hex.validate",
          "group": "HexGroup1@1",
          "when": "isFileSystemResource && !explorerResourceIsFolder && resourceScheme == file &&  resourceFilename =~ /\\.json$/"
        },
        {
          "command": "hex.select",
          "group": "HexGroup2@1"
        }
      ],
      "explorer/context": [
        {
          "command": "hex.validate",
          "group": "HexGroup@1",
          "when": "isFileSystemResource && !explorerResourceIsFolder && resourceScheme == file &&  resourceFilename =~ /\\.json$/"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.js --production",
    "build:dev": "node esbuild.config.js",
    "build:watch": "node esbuild.config.js --watch",
    "update": "npx npm-check-updates -u && npm install",
    "pr": "gt submit -p --ai",
    "lint": "eslint src/",
    "package": "node scripts/assure-clean-vsix-directory.mjs && npm run build && npx @vscode/vsce package --no-dependencies --skip-license -o vsix/",
    "publish:vsce": "npm run package && npx @vscode/vsce publish --packagePath vsix/*.vsix --pat $VSX_MARKETPLACE_ACCESS_TOKEN",
    "publish:ovsx": "npm run package && npx ovsx publish --packagePath vsix/*.vsix --pat $OVSX_ACCESS_TOKEN",
    "patch": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "postinstall": "node scripts/postinstall.js"
  },
  "icon": "hexagon.png",
  "type": "module",
  "dependencies": {
    "@gesslar/toolkit": "^5.2.0",
    "@vscode/codicons": "^0.0.45",
    "json5": "^2.2.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@gesslar/uglier": "^2.4.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@vscode/vsce": "^3.9.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0"
  }
}
